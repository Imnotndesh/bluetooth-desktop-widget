<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.bluetooth-desktop-widget"
          path="/org/gnome/shell/extensions/bluetooth-desktop-widget/">

    <key name="widgets-config" type="s">
      <default>'[{"id":"bluetooth","enabled":true}]'</default>
      <summary>Enabled widgets and their order</summary>
      <description>
        JSON-encoded list of widget entries, each with an "id" and
        "enabled" flag. Array order determines stacking order on the
        desktop.
      </description>
    </key>

    <key name="widget-style" type="s">
      <choices>
        <choice value="list"/>
        <choice value="circles"/>
      </choices>
      <default>"circles"</default>
      <summary>Bluetooth widget layout style</summary>
      <description>
        "list" shows one row per device with a small battery icon.
        "circles" shows an iOS-battery-widget-style row of circular
        percentage rings.
      </description>
    </key>

    <!-- Weather widget (proof-of-concept keys for future use) -->
    <key name="weather-api-key" type="s">
      <default>''</default>
      <summary>OpenWeather API key</summary>
      <description>User-supplied API key for the weather widget.</description>
    </key>
    <key name="weather-location" type="s">
      <default>''</default>
      <summary>Weather location</summary>
      <description>City name or lat,lon used to query the weather API.</description>
    </key>

    <key name="photos-instance-url" type="s">
      <default>''</default>
      <summary>Immich instance URL</summary>
    </key>
    <key name="photos-album-id" type="s">
      <default>''</default>
      <summary>Selected Immich album id</summary>
    </key>
    <key name="photos-album-name" type="s">
      <default>''</default>
      <summary>Selected Immich album display name</summary>
    </key>

    <!-- Storage widget -->
    <key name="storage-mount-path" type="s">
      <default>'/'</default>
      <summary>Filesystem path to report storage usage for</summary>
    </key>

  </schema>
</schemalist>